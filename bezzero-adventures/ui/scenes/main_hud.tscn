[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://ui/scripts/main_hud.gd" id="1_hud"]

[node name="MainHud" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_hud")

[node name="CenterContainer" type="CenterContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="VBoxContainer" type="VBoxContainer" parent="CenterContainer"]
layout_mode = 2
theme_override_constants/separation = 12

[node name="Title" type="Label" parent="CenterContainer/VBoxContainer"]
layout_mode = 2
theme_override_font_sizes/font_size = 24
text = "Bezzero Adventures"
horizontal_alignment = 1

[node name="PlayButton" type="Button" parent="CenterContainer/VBoxContainer"]
layout_mode = 2
text = "Play"

[node name="ExitButton" type="Button" parent="CenterContainer/VBoxContainer"]
layout_mode = 2
text = "Sair"

[node name="SetupBox" type="VBoxContainer" parent="CenterContainer/VBoxContainer"]
layout_mode = 2
theme_override_constants/separation = 8

[node name="NameLabel" type="Label" parent="CenterContainer/VBoxContainer/SetupBox"]
layout_mode = 2
text = "Nome do jogador"

[node name="NameInput" type="LineEdit" parent="CenterContainer/VBoxContainer/SetupBox"]
layout_mode = 2
placeholder_text = "Digite seu nome"

[node name="StartButton" type="Button" parent="CenterContainer/VBoxContainer/SetupBox"]
layout_mode = 2
text = "Iniciar jogo"

[node name="FeedbackLabel" type="Label" parent="CenterContainer/VBoxContainer/SetupBox"]
layout_mode = 2
modulate = Color(1, 0.45, 0.45, 1)
text = ""

[node name="BackButton" type="Button" parent="."]
layout_mode = 0
offset_left = 10.0
offset_top = 10.0
offset_right = 36.0
offset_bottom = 34.0
text = "←"

[connection signal="pressed" from="CenterContainer/VBoxContainer/PlayButton" to="." method="_on_play_button_pressed"]
[connection signal="pressed" from="CenterContainer/VBoxContainer/ExitButton" to="." method="_on_exit_button_pressed"]
[connection signal="pressed" from="BackButton" to="." method="_on_back_button_pressed"]
[connection signal="text_submitted" from="CenterContainer/VBoxContainer/SetupBox/NameInput" to="." method="_on_name_input_text_submitted"]
[connection signal="pressed" from="CenterContainer/VBoxContainer/SetupBox/StartButton" to="." method="_on_start_button_pressed"]
